pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    booleanParam(name: 'PUSH_ACR_RELEASE', defaultValue: false, description: 'Push formal images to Aliyun ACR only when this is true.')
    string(name: 'RELEASE_VERSION', defaultValue: '', trim: true, description: 'Formal image version, for example v0.2.0. Required when PUSH_ACR_RELEASE=true.')
    booleanParam(name: 'PUSH_LATEST', defaultValue: false, description: 'Also push latest. Keep false unless latest should be moved intentionally.')
  }

  environment {
    COMPOSE_FILE = 'deploy/jenkins/docker-compose.local-test.yml'
    MAVEN_IMAGE = 'maven:3.9-eclipse-temurin-17'
    NODE_IMAGE = 'node:22'
    ACR_REGISTRY = 'registry.cn-hangzhou.aliyuncs.com'
    ACR_NAMESPACE = 'smartwarehouse'
    ACR_CREDENTIALS_ID = 'aliyun-acr-smartwarehouse'
    MAVEN_CACHE_VOLUME = 'smartwarehouse_maven_cache'
    PNPM_STORE_VOLUME = 'smartwarehouse_pnpm_store'
    MAVEN_OPTS = '-Dfile.encoding=UTF-8'
    NODE_OPTIONS = '--max-old-space-size=4096'
    MYSQL_ROOT_PASSWORD = 'smart_root_dev'
    MYSQL_APP_USER = 'smart_sys'
    MYSQL_APP_PASSWORD = 'smart_sys_dev'
    MYSQL_PORT = '23306'
    REDIS_PORT = '26381'
    RABBITMQ_PORT = '25673'
    RABBITMQ_MANAGEMENT_PORT = '35673'
    NACOS_PORT = '28848'
    NACOS_GRPC_PORT = '29848'
    SMARTWAREHOUSE_JWT_SECRET = 'change-me-in-local-jenkins-only-at-least-32chars'
    SMARTWAREHOUSE_DEMO_PASSWORD = '123456'
    SMARTWAREHOUSE_HOST_CHECK_BASE = 'http://host.docker.internal'
    SMARTWAREHOUSE_TEST_DATASOURCE_URL = 'jdbc:mysql://host.docker.internal:23306/smart_sys?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai'
    SMARTWAREHOUSE_TEST_REDIS_HOST = 'host.docker.internal'
    SMARTWAREHOUSE_TEST_REDIS_PORT = '26381'
    SMARTWAREHOUSE_TEST_NACOS_SERVER_ADDR = 'host.docker.internal:28848'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Docker Info') {
      steps {
        sh '''
          set -eu
          docker version
          docker compose version
          docker volume create "$MAVEN_CACHE_VOLUME" >/dev/null
          docker volume create "$PNPM_STORE_VOLUME" >/dev/null

          JENKINS_CONTAINER_ID="$(cat /etc/hostname)"
          docker run --rm \
            --volumes-from "$JENKINS_CONTAINER_ID" \
            -v "$MAVEN_CACHE_VOLUME:/root/.m2" \
            -w "$WORKSPACE" \
            "$MAVEN_IMAGE" \
            mvn -version

          docker run --rm \
            --volumes-from "$JENKINS_CONTAINER_ID" \
            -v "$PNPM_STORE_VOLUME:/pnpm-store" \
            -w "$WORKSPACE/frontend-platform" \
            "$NODE_IMAGE" \
            bash -lc 'node -v && corepack --version'
        '''
      }
    }

    stage('Validate ACR Release') {
      steps {
        sh '''
          set -eu

          push_acr_release="${PUSH_ACR_RELEASE:-false}"
          release_version_param="${RELEASE_VERSION:-}"
          push_latest="${PUSH_LATEST:-false}"

          if [ "$push_acr_release" != "true" ]; then
            echo "PUSH_ACR_RELEASE=false, skip ACR release validation and push."
            exit 0
          fi

          release_version="$(printf '%s' "$release_version_param" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
          release_version_lower="$(printf '%s' "$release_version" | tr '[:upper:]' '[:lower:]')"

          if [ -z "$release_version" ]; then
            echo "RELEASE_VERSION is required when PUSH_ACR_RELEASE=true." >&2
            exit 1
          fi

          case "$release_version_lower" in
            test|dev|latest)
              echo "RELEASE_VERSION must not be test, dev, or latest for formal ACR release." >&2
              exit 1
              ;;
          esac

          case "$release_version" in
            .*|-*|*[!A-Za-z0-9_.-]*)
              echo "RELEASE_VERSION contains invalid Docker tag characters: $release_version" >&2
              exit 1
              ;;
          esac

          if [ "${#release_version}" -gt 128 ]; then
            echo "RELEASE_VERSION is longer than Docker tag limit 128 characters." >&2
            exit 1
          fi

          echo "ACR formal release is enabled for version: $release_version"
          if [ "$push_latest" = "true" ]; then
            echo "PUSH_LATEST=true, latest tag will also be pushed after versioned images."
          fi
        '''
      }
    }

    stage('Local Middleware Up') {
      steps {
        sh '''
          set -eu
          docker compose -f "$COMPOSE_FILE" up -d mysql redis rabbitmq nacos

          wait_healthy() {
            service="$1"
            for i in $(seq 1 60); do
              cid="$(docker compose -f "$COMPOSE_FILE" ps -q "$service" || true)"
              if [ -n "$cid" ]; then
                status="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' "$cid" 2>/dev/null || true)"
                if [ "$status" = "healthy" ] || [ "$status" = "running" ]; then
                  echo "$service is $status"
                  return 0
                fi
              fi
              sleep 5
            done
            docker compose -f "$COMPOSE_FILE" ps
            docker compose -f "$COMPOSE_FILE" logs --tail=120 "$service"
            exit 1
          }

          wait_healthy mysql
          wait_healthy redis
          wait_healthy rabbitmq
          wait_healthy nacos
          docker compose -f "$COMPOSE_FILE" ps
        '''
      }
    }

    stage('Init MySQL') {
      steps {
        sh '''
          set -eu
          docker compose -f "$COMPOSE_FILE" exec -T mysql sh -c 'mysql --default-character-set=utf8mb4 -uroot -p"$MYSQL_ROOT_PASSWORD"' < deploy/mysql/init-sys-db.sql
          docker compose -f "$COMPOSE_FILE" exec -T mysql sh -c 'mysql --default-character-set=utf8mb4 -u"$MYSQL_USER" -p"$MYSQL_PASSWORD" "$MYSQL_DATABASE" -e "select username,status from sys_user; select module_code,status,remote_entry from sys_frontend_module;"'
        '''
      }
    }

    stage('Java Test') {
      steps {
        sh '''
          set -eu
          JENKINS_CONTAINER_ID="$(cat /etc/hostname)"
          docker run --rm \
            --volumes-from "$JENKINS_CONTAINER_ID" \
            --add-host=host.docker.internal:host-gateway \
            -v "$MAVEN_CACHE_VOLUME:/root/.m2" \
            -w "$WORKSPACE" \
            -e MAVEN_OPTS="$MAVEN_OPTS" \
            -e SMARTWAREHOUSE_SYS_DATASOURCE_URL="$SMARTWAREHOUSE_TEST_DATASOURCE_URL" \
            -e SMARTWAREHOUSE_SYS_DATASOURCE_USERNAME="$MYSQL_APP_USER" \
            -e SMARTWAREHOUSE_SYS_DATASOURCE_PASSWORD="$MYSQL_APP_PASSWORD" \
            -e SMARTWAREHOUSE_REDIS_HOST="$SMARTWAREHOUSE_TEST_REDIS_HOST" \
            -e SMARTWAREHOUSE_REDIS_PORT="$SMARTWAREHOUSE_TEST_REDIS_PORT" \
            -e SMARTWAREHOUSE_NACOS_SERVER_ADDR="$SMARTWAREHOUSE_TEST_NACOS_SERVER_ADDR" \
            -e SMARTWAREHOUSE_JWT_SECRET="$SMARTWAREHOUSE_JWT_SECRET" \
            -e SMARTWAREHOUSE_DEMO_PASSWORD="$SMARTWAREHOUSE_DEMO_PASSWORD" \
            "$MAVEN_IMAGE" \
            mvn test
        '''
      }
    }

    stage('Java Package') {
      steps {
        sh '''
          set -eu
          JENKINS_CONTAINER_ID="$(cat /etc/hostname)"
          docker run --rm \
            --volumes-from "$JENKINS_CONTAINER_ID" \
            -v "$MAVEN_CACHE_VOLUME:/root/.m2" \
            -w "$WORKSPACE" \
            -e MAVEN_OPTS="$MAVEN_OPTS" \
            "$MAVEN_IMAGE" \
            mvn clean package -DskipTests
        '''
      }
    }

    stage('Frontend Install') {
      steps {
        sh '''
          set -eu
          JENKINS_CONTAINER_ID="$(cat /etc/hostname)"
          docker run --rm \
            --volumes-from "$JENKINS_CONTAINER_ID" \
            -v "$PNPM_STORE_VOLUME:/pnpm-store" \
            -w "$WORKSPACE/frontend-platform" \
            -e COREPACK_ENABLE_DOWNLOAD_PROMPT=0 \
            -e NODE_OPTIONS="$NODE_OPTIONS" \
            "$NODE_IMAGE" \
            bash -lc 'corepack enable && corepack prepare pnpm@10.12.1 --activate && pnpm config set store-dir /pnpm-store && pnpm install --frozen-lockfile'
        '''
      }
    }

    stage('Frontend Build') {
      steps {
        sh '''
          set -eu
          JENKINS_CONTAINER_ID="$(cat /etc/hostname)"
          docker run --rm \
            --volumes-from "$JENKINS_CONTAINER_ID" \
            -v "$PNPM_STORE_VOLUME:/pnpm-store" \
            -w "$WORKSPACE/frontend-platform" \
            -e COREPACK_ENABLE_DOWNLOAD_PROMPT=0 \
            -e NODE_OPTIONS="$NODE_OPTIONS" \
            "$NODE_IMAGE" \
            bash -lc 'corepack enable && corepack prepare pnpm@10.12.1 --activate && pnpm config set store-dir /pnpm-store && pnpm build:packages && pnpm --filter @smartwarehouse/portal-shell build && pnpm --filter @smartwarehouse/sys-web build'
        '''
      }
    }

    stage('Docker Build') {
      steps {
        sh '''
          set -eu
          docker build -f gateway/deploy/Dockerfile -t smartwarehouse/gateway-service:"$BUILD_NUMBER" -t smartwarehouse/gateway-service:test .
          docker build -f sys/deploy/Dockerfile -t smartwarehouse/sys-service:"$BUILD_NUMBER" -t smartwarehouse/sys-service:test .
          docker build -f frontend-platform/apps/portal-shell/deploy/Dockerfile -t smartwarehouse/portal-shell:"$BUILD_NUMBER" -t smartwarehouse/portal-shell:test .
          docker build -f frontend-platform/apps/sys-web/deploy/Dockerfile -t smartwarehouse/sys-web:"$BUILD_NUMBER" -t smartwarehouse/sys-web:test .
        '''
      }
    }

    stage('Local Test Deploy') {
      steps {
        sh '''
          set -eu
          docker compose -f "$COMPOSE_FILE" up -d --force-recreate sys-service gateway-service portal-shell sys-web
          docker compose -f "$COMPOSE_FILE" ps
        '''
      }
    }

    stage('Health Check') {
      steps {
        sh '''
          set -eu
          check_url() {
            url="$1"
            for i in $(seq 1 60); do
              if curl -fsS "$url" >/dev/null; then
                echo "OK $url"
                return 0
              fi
              sleep 3
            done
            docker compose -f "$COMPOSE_FILE" ps
            docker compose -f "$COMPOSE_FILE" logs --tail=160 gateway-service sys-service portal-shell sys-web
            echo "Failed health check: $url" >&2
            exit 1
          }

          check_url "$SMARTWAREHOUSE_HOST_CHECK_BASE:9200/actuator/health"
          check_url "$SMARTWAREHOUSE_HOST_CHECK_BASE:9201/actuator/health"
          check_url "$SMARTWAREHOUSE_HOST_CHECK_BASE:5174/"
          check_url "$SMARTWAREHOUSE_HOST_CHECK_BASE:5175/apps/sys/assets/remoteEntry.js"
          check_url "$SMARTWAREHOUSE_HOST_CHECK_BASE:9200/api/sys/auth/risk-state?username=admin"
        '''
      }
    }

    stage('ACR Release Push') {
      when {
        expression { return params.PUSH_ACR_RELEASE }
      }
      steps {
        withCredentials([usernamePassword(credentialsId: env.ACR_CREDENTIALS_ID, usernameVariable: 'ACR_USERNAME', passwordVariable: 'ACR_PASSWORD')]) {
          sh '''
            set -eu

            release_version_param="${RELEASE_VERSION:-}"
            push_latest="${PUSH_LATEST:-false}"
            release_version="$(printf '%s' "$release_version_param" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            release_file="acr-release-images.txt"
            rm -f "$release_file"

            printf '%s\\n' "$ACR_PASSWORD" | docker login "$ACR_REGISTRY" --username "$ACR_USERNAME" --password-stdin

            tag_push_and_verify() {
              service_name="$1"
              local_image="smartwarehouse/$service_name:test"
              remote_image="$ACR_REGISTRY/$ACR_NAMESPACE/$service_name:$release_version"

              docker tag "$local_image" "$remote_image"
              docker push "$remote_image"
              docker manifest inspect "$remote_image" >/dev/null
              printf '%s\\n' "$remote_image" >> "$release_file"

              if [ "$push_latest" = "true" ]; then
                latest_image="$ACR_REGISTRY/$ACR_NAMESPACE/$service_name:latest"
                docker tag "$local_image" "$latest_image"
                docker push "$latest_image"
                docker manifest inspect "$latest_image" >/dev/null
                printf '%s\\n' "$latest_image" >> "$release_file"
              fi
            }

            tag_push_and_verify gateway-service
            tag_push_and_verify sys-service
            tag_push_and_verify portal-shell
            tag_push_and_verify sys-web

            echo "ACR release images:"
            cat "$release_file"
          '''
        }
      }
    }

    stage('Archive') {
      steps {
        archiveArtifacts artifacts: 'acr-release-images.txt,**/target/*.jar,frontend-platform/apps/*/dist/**', allowEmptyArchive: true
        junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
      }
    }
  }

  post {
    success {
      sh '''
        set +e

        remove_image_tag() {
          image_tag="$1"
          if docker image inspect "$image_tag" >/dev/null 2>&1; then
            echo "Remove local image tag: $image_tag"
            docker rmi "$image_tag" || true
          else
            echo "Skip missing local image tag: $image_tag"
          fi
        }

        for service_name in gateway-service sys-service portal-shell sys-web; do
          remove_image_tag "smartwarehouse/$service_name:$BUILD_NUMBER"
        done

        push_acr_release="${PUSH_ACR_RELEASE:-false}"
        push_latest="${PUSH_LATEST:-false}"
        release_version_param="${RELEASE_VERSION:-}"
        release_version="$(printf '%s' "$release_version_param" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

        if [ "$push_acr_release" = "true" ] && [ -n "$release_version" ]; then
          for service_name in gateway-service sys-service portal-shell sys-web; do
            remove_image_tag "$ACR_REGISTRY/$ACR_NAMESPACE/$service_name:$release_version"
            if [ "$push_latest" = "true" ]; then
              remove_image_tag "$ACR_REGISTRY/$ACR_NAMESPACE/$service_name:latest"
            fi
          done
        fi

        docker image prune -f || true
      '''
    }

    always {
      sh '''
        docker compose -f "$COMPOSE_FILE" ps || true
        docker logout "$ACR_REGISTRY" || true
      '''
    }
  }
}
